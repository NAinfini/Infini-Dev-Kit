{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "composite": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noImplicitOverride": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "lib": ["ES2022", "DOM"],
    "jsx": "react-jsx",
    "types": ["node", "vitest/globals"],
    "baseUrl": ".",
    "paths": {
      "@infini-dev-kit/utils": ["packages/utils"],
      "@infini-dev-kit/utils/*": ["packages/utils/*"],
      "@infini-dev-kit/theme-core": ["packages/theme-core"],
      "@infini-dev-kit/theme-core/*": ["packages/theme-core/*"],
      "@infini-dev-kit/adapter-mantine": ["packages/adapter-mantine"],
      "@infini-dev-kit/adapter-mantine/*": ["packages/adapter-mantine/*"],
      "@infini-dev-kit/react": ["packages/react"],
      "@infini-dev-kit/react/*": ["packages/react/*"],
      "@infini-dev-kit/api-client": ["packages/api-client"],
      "@infini-dev-kit/api-client/*": ["packages/api-client/*"],
      "@infini-dev-kit/bot-core": ["packages/bot-core"],
      "@infini-dev-kit/bot-core/*": ["packages/bot-core/*"],
      "@infini-dev-kit/bot-discord": ["packages/bot-discord"],
      "@infini-dev-kit/bot-discord/*": ["packages/bot-discord/*"],
      "@infini-dev-kit/bot-wechat": ["packages/bot-wechat"],
      "@infini-dev-kit/bot-wechat/*": ["packages/bot-wechat/*"],
      "@infini-dev-kit/adapter-shadcn": ["packages/adapter-shadcn"],
      "@infini-dev-kit/adapter-shadcn/*": ["packages/adapter-shadcn/*"],
      "@infini-dev-kit/adapter-radix": ["packages/adapter-radix"],
      "@infini-dev-kit/adapter-radix/*": ["packages/adapter-radix/*"],
      "@infini-dev-kit/adapter-mui": ["packages/adapter-mui"],
      "@infini-dev-kit/adapter-mui/*": ["packages/adapter-mui/*"],
      "@infini-dev-kit/adapter-antd": ["packages/adapter-antd"],
      "@infini-dev-kit/adapter-antd/*": ["packages/adapter-antd/*"]
    }
  }
}
